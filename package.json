{
  "name": "marko-skeleton-inertia-vue",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "build:ssr": "vite build --ssr app/web/resources/js/ssr.js --outDir bootstrap/ssr",
    "dev:all": "npm run build:ssr && concurrently -k \"php -S 0.0.0.0:8000 -t public/\" \"npx vite --host\" \"node bootstrap/ssr/ssr.js\" --names \"PHP,VITE,SSR\" --prefix-colors \"blue,green,yellow\"",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test:ui": "vitest run",
    "test:e2e": "playwright test",
    "quality": "npm run lint && npm run format:check && npm run test:ui"
  },
  "dependencies": {
    "@inertiajs/vue3": "^1.2",
    "@tailwindcss/vite": "^4.2.2",
    "@vue/server-renderer": "^3.5.32",
    "tailwindcss": "^4.2.2",
    "vue": "^3.5"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.0",
    "@eslint/js": "^9.39.1",
    "@playwright/test": "^1.57.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/vue": "^8.1.0",
    "@vitejs/plugin-vue": "^5.2",
    "@vue/test-utils": "^2.4.6",
    "concurrently": "^9.2.1",
    "eslint": "^9.39.1",
    "eslint-plugin-vue": "^10.6.2",
    "globals": "^16.5.0",
    "jsdom": "^27.3.0",
    "prettier": "^3.7.3",
    "vite": "^6.0",
    "vitest": "^4.0.15"
  }
}
